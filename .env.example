# Supabase — copiá este archivo a .env.local y completá los valores
# Los valores se obtienen en: https://supabase.com/dashboard → proyecto → Settings → API

# Público: se puede exponer al browser
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Privado: NUNCA exponer al browser ni commitear el valor real
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
